{
  "_comment": "Placeholder dashboard scaffold. Build the real dashboard in SimHub Dash Studio and export over this file. The properties listed below are exposed by the plugin and ready to bind via NCalc.",
  "name": "Pit Strategy",
  "version": "0.1.0",
  "size": { "width": 1920, "height": 480 },
  "boundProperties": [
    "PitStrategy.Decision.Kind",
    "PitStrategy.Decision.Confidence",
    "PitStrategy.Decision.PrimaryReason",
    "PitStrategy.Decision.RecommendedPitLap",
    "PitStrategy.PitLoss.Total",
    "PitStrategy.PitLoss.PitLaneTravel",
    "PitStrategy.PitLoss.FuelService",
    "PitStrategy.PitLoss.TireService",
    "PitStrategy.PitLoss.EntryExitDelta",
    "PitStrategy.Traffic.IsCleanAir",
    "PitStrategy.Traffic.RejoinPosition",
    "PitStrategy.Traffic.GapAhead",
    "PitStrategy.Traffic.GapBehind",
    "PitStrategy.Traffic.CleanAirLapIfWait",
    "PitStrategy.Fuel.Level",
    "PitStrategy.Fuel.PerLapAverage",
    "PitStrategy.Fuel.LapsToEmpty",
    "PitStrategy.Fuel.LapsToEmptyAtMargin",
    "PitStrategy.Fuel.MinFuelToAdd",
    "PitStrategy.Fuel.HasEnoughData",
    "PitStrategy.Pit.RecommendedLap",
    "PitStrategy.Pit.LapsUntilPit",
    "PitStrategy.Pit.StintsRemaining",
    "PitStrategy.Undercut.IsActive",
    "PitStrategy.Undercut.RivalCarIdx",
    "PitStrategy.Undercut.ExpectedGain",
    "PitStrategy.Fcy.IsOpportunity",
    "PitStrategy.Fcy.TimeSavings",
    "PitStrategy.Fcy.Active"
  ],
  "exampleBindings": {
    "decisionKindText": "[PitStrategy.Decision.Kind]",
    "decisionColor": "if([PitStrategy.Decision.Kind] = 'PitNow' and [PitStrategy.Decision.Confidence] > 0.7, '#34C759', if([PitStrategy.Decision.Kind] = 'PitNow', '#FFCC00', if([PitStrategy.Decision.Kind] = 'StayOut', '#1E2329', '#FF9500')))",
    "confidenceText": "format([PitStrategy.Decision.Confidence] * 100, '0') + '%'",
    "trafficBannerColor": "if([PitStrategy.Traffic.IsCleanAir] = true, '#34C759', '#FF3B30')",
    "trafficText": "'P' + [PitStrategy.Traffic.RejoinPosition] + '  ▼ ' + format([PitStrategy.Traffic.GapBehind], '0.0') + 's   ▲ ' + format([PitStrategy.Traffic.GapAhead], '0.0') + 's'",
    "fuelLapsToEmptyText": "format([PitStrategy.Fuel.LapsToEmpty], '0.0')",
    "fuelToAddText": "format([PitStrategy.Fuel.MinFuelToAdd], '0.0') + 'L'",
    "undercutVisibility": "[PitStrategy.Undercut.IsActive] = true",
    "undercutBadgeText": "'CAR #' + [PitStrategy.Undercut.RivalCarIdx] + '  +' + format([PitStrategy.Undercut.ExpectedGain], '0.0') + 's'",
    "fcyVisibility": "[PitStrategy.Fcy.IsOpportunity] = true",
    "fcyBadgeText": "'PIT NOW: save ' + format([PitStrategy.Fcy.TimeSavings], '0.0') + 's vs green stop'"
  }
}
